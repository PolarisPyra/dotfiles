{
  "monitors": {
    "DP-5": {
      "name": "bar",
      "position": "top",
      "height": 10,
      "transition_type": "none",
      "start": [
        {
          "bar": [
            {
              "on_click": "!wlogout -m 200 -r 20 -c 20 -s -n",
              "label": "<span font-size='14pt'></span>",
              "name": "power-btn",
              "type": "button"
            }
          ],
          "class": "power-menu",
          "type": "custom"
        },
        {
          "type": "script",
          "cmd": "~/.config/ironbar/weather.sh",
          "mode": "poll",
          "interval": 60000
        },
        {
          "type": "music",
          "player_type": "mpd",
          "format": "{title} / {artist}"
        }
      ],
      "center": [
        {
          "type": "workspaces",
          "name_map": {
            "1": "●",
            "2": "●",
            "3": "●",
            "4": "●",
            "5": "●"
          },
          "sort": "name",
          "favorites": ["1", "2", "3", "4", "5"]
        }
      ],
      "end": [
        {
          "type": "tray"
        },
        {
          "format": ["CPU {cpu_frequency} GHz"],
          "interval": {
            "cpu": 1,
            "disks": 300,
            "memory": 30,
            "networks": 3,
            "temps": 5
          },
          "type": "sys_info"
        },
        {
          "type": "clock",
          "format": "%I:%M:%S %p"
        },
        {
          "type": "volume",
          "format": "{icon} {percentage}%",
          "max_volume": 100,
          "icons": {
            "volume_high": "󰕾",
            "volume_medium": "󰖀",
            "volume_low": "󰕿",
            "muted": "󰝟"
          }
        }
      ]
    },
    "DP-6": {

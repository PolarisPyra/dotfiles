{
  "monitors": {
    "DP-5": {
      "name": "bar",
      "position": "top",
      "height": 30,
      "transition_type": "none",
      "start": [
        {
          "type": "script",
          "cmd": "~/.config/ironbar/weather.sh",
          "mode": "poll",
          "interval": 60000
        },
        {
          "type": "music",
          "player_type": "mpris",
          "format": "{title} / {artist}",
          "icons": {
            "play": "",
            "pause": ""
          }
        }
      ],
      "center": [
        {
          "type": "workspaces",
          "name_map": {
            "1": "●",
            "2": "●",
            "3": "●",
            "4": "●",
            "5": "●"
          },
          "sort": "name",
          "all_monitors": false,
          "favorites": ["1", "2", "3", "4", "5"]
        }
      ],
      "end": [
        {
          "type": "tray"
        },

        {
          "format": [" CPU {cpu_frequency} GHz"],
          "interval": {
            "cpu": 1,
            "disks": 300,
            "memory": 30,
            "networks": 3,
            "temps": 5
          },
          "type": "sys_info"
        },
        {
          "type": "clock",
          "format": "%I:%M:%S %p %d/%m/%y"
        }
      ]
    },
    "DP-6": {
      "name": "bar",
      "position": "top",
      "height": 30,
      "transition_type": "none",
      "start": [
        {
          "type": "clock",
          "format": "%H:%M:%S %d/%m/%y"
        },
        {
          "type": "script",
          "cmd": "~/.config/ironbar/weather.sh",
          "mode": "poll",
          "interval": 60000
        }
      ],
      "center": [
        {
          "type": "workspaces",
          "name_map": {
            "6": "●",
            "7": "●",
            "8": "●",
            "9": "●",
            "10": "●"
          },
          "sort": "name",
          "all_monitors": false,
          "favorites": ["6", "7", "8", "9", "10"]
        }
      ],
      "end": [
        {
          "format": ["CPU {cpu_percent}% {cpu_frequency} GHz |"],
          "interval": {
            "cpu": 1,
            "disks": 300,
            "memory": 30,
            "networks": 3,
            "temps": 5
          },
          "type": "sys_info"
        }
      ]
    }
  }
}

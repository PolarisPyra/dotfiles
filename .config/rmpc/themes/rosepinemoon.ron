#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    draw_borders: false,
    show_song_table_header: false,
    symbols: (song: "🎵", dir: "📁", marker: "\u{e0b0}"),
    layout: Split(
        direction: Vertical,
        panes: [
            (
                pane: Pane(Header),
                size: "1",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                pane: Pane(ProgressBar),
                size: "1",
            ),
        ],
    ),
    progress_bar: (
        symbols: ["", "⭘", " "],
        track_style: (bg: "#2a273f"),
        elapsed_style: (fg: "#c4a7e7", bg: "#2a273f"),
        thumb_style: (fg: "#c4a7e7", bg: "#2a273f"),
    ),
    scrollbar: (
        symbols: ["│", "█", "▲", "▼"],
        track_style: (),
        ends_style: (),
        thumb_style: (fg: "#908caa"),
    ),
    browser_column_widths: [20, 38, 42],
    text_color: "#e0def4",
    background_color: "#232136",
    header_background_color: "#2a273f",
    modal_background_color: None,
    modal_backdrop: false,
    tab_bar: (active_style: (fg: "#232136", bg: "#c4a7e7", modifiers: "Bold"), inactive_style: ()),
    borders_style: (fg: "#6e6a86"),
    highlighted_item_style: (fg: "#c4a7e7", modifiers: "Bold"),
    current_item_style: (fg: "#232136", bg: "#908caa", modifiers: "Bold"),
    highlight_border_style: (fg: "#908caa"),
    song_table_format: [
        (
            prop: (kind: Property(Artist), style: (fg: "#908caa"), default: (kind: Text("Unknown"))),
            width: "50%",
            alignment: Right,
        ),
        (
            prop: (kind: Text("-"), style: (fg: "#908caa"), default: (kind: Text("Unknown"))),
            width: "1",
            alignment: Center,
        ),
        (
            prop: (kind: Property(Title), style: (fg: "#9ccfd8"), default: (kind: Text("Unknown"))),
            width: "50%",
        ),
    ],
    header: (
        rows: [
            (
                left: [
                    (kind: Text("["), style: (fg: "#908caa", modifiers: "Bold")),
                    (kind: Property(Status(State)), style: (fg: "#908caa", modifiers: "Bold")),
                    (kind: Text("]"), style: (fg: "#908caa", modifiers: "Bold"))
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#f6c177", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "#f6c177", modifiers: "Bold"))
                    ),
                    (kind: Text(" - ")),
                    (kind: Property(Song(Title)), style: (fg: "#9ccfd8", modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (fg: "#9ccfd8", modifiers: "Bold"))
                    )
                ],
                right: [
                    (kind: Text("Vol: "), style: (fg: "#908caa", modifiers: "Bold")),
                    (kind: Property(Status(Volume)), style: (fg: "#908caa", modifiers: "Bold")),
                    (kind: Text("% "), style: (fg: "#908caa", modifiers: "Bold"))
                ]
            )
        ],
    ),
)
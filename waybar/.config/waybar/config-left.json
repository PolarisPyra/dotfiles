{
  "layer": "top",
  "output": "DP-5",
  "modules-center": ["hyprland/workspaces"],
  "modules-left": ["custom/os", "clock", "memory", "cpu", "disk", "privacy"],
  "modules-right": ["custom/swaync", "tray", "network", "pulseaudio"],
  "privacy": {
    "icon-size": 12,
    "icon-spacing": 5,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 12
      }
    ]
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 12,
    "height": 10,
    "on-click": "activate",
    "on-click-middle": "close"
  },
  "custom/os": {
    "format": "≤░μΘ",
    "tooltip": false,
    "on-click": "sh $HOME/.config/waybar/scripts/logout.sh"
  },
  "tray": {
    "icon-size": 18,
    "margin": 4,
    "spacing": 10,
    "tooltip": true,
    "format": "{icon}",
    "tooltip-format": "{icon} {status}",
    "tooltip-size": 20
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "<span color='#B37F34'><small>ΎΔπ</small></span>",
      "balanced": "<span><small>ΎΚΟ </small></span>",
      "power-saver": "<span color='#a6e3a1'><small>ΎΒυ</small></span>"
    }
  },
  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G ≤░╛Η / {total:0.1f}G",
    "format-alt": "{percentage}% ≤░╛Η",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "kitty --title btop sh -c 'btop'"
  },
  "cpu": {
    "interval": 10,
    "format": "≤░αγ {usage}≤▒Κ╕"
  },
  "disk": {
    "interval": 60,
    "format": "≤░Η╝ {percentage_used}≤▒Κ╕",
    "path": "/"
  },
  "mpris": {
    "interval": 10,
    "format": "{player_icon} ",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",
    "smooth-scrolling-threshold": 1,
    "player-icons": {
      "chromium": "ΎΚρ",
      "default": "ΎΑζ",
      "firefox": "ΎΚσ",
      "kdeconnect": "Ύαθ",
      "mopidy": "ΎΑΒ",
      "mpv": "≤░Ρ╣",
      "spotify": "ΎΗ╝",
      "vlc": "≤░Χ╝"
    },
    "status-icons": {
      "paused": "≤░ΡΟ",
      "playing": "ΎΒΜ",
      "stopped": "ΎΒΞ"
    },
    "ignored-players": ["firefox"],
    "max-length": 30
  },
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "sort-by-number": true,
    "format": "{icon} {name}",
    "show-special": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΝ"
    }
  },
  "clock": {
    "format": "<span color='#b4befe'>ΎΑΩ </span> {:%I:%M %p  %A, %b %d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "pulseaudio": {
    "format": "<span color='#b4befe'>{icon} </span> {volume}%",
    "format-muted": "≤░ζθ ",
    "tooltip": false,
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "≤░Χ╛", "≤░Χ╛", "ΎΑρ", "ΎΑρ", "ΎΑρ"]
    },
    "scroll-step": 1,
    "on-scroll-up": "~/.config/hypr/scripts/volume.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/volume.sh --dec",
    "on-click": "~/.config/hypr/scripts/volume.sh --toggle"
  },
  "network": {
    "interface": "wlo1",
    "format": "{ifname}",
    "format-wifi": "{icon}  {essid}",
    "format-ethernet": "Ό╜Ε ",
    "format-disconnected": "≤░νψ ",
    "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBits} ΎΕ║ {bandwidthDownBits}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 30,
    "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
    "on-click-right": "~/.config/hypr/scripts/network.sh",
    "on-click": "nm-connection-editor"
  },
  "network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "ΎΕ║ {bandwidthDownBytes} ΎΕ╣ {bandwidthUpBytes} ",
    "format-ethernet": "{icon}ΎΕ║ {bandwidthDownBytes} ΎΕ║ {bandwidthUpBytes} ",
    "format-disconnected": "≤░Νβ",
    "tooltip-format": "{ipaddr}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 30
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "none": "ΎΓλ",
      "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-none": "ΎΘ╖",
      "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-inhibited-none": "ΎΘ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}

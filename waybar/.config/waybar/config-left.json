{
  "layer": "top",
  "output": "DP-5",
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-left": [
    "custom/os",
    "clock",
    "memory",
    "cpu",
    "disk",
    "privacy"
  ],
  "modules-right": [
    "custom/swaync",
    "tray",
    "network",
    "pulseaudio"
 
  ],
  "privacy": {
    "icon-size": 12,
    "icon-spacing": 5,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 12
      }
    ]
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 12,
    "height": 10,
    "on-click": "activate",
    "on-click-middle": "close"
  },
  "custom/os": {
    "format": "у°®Ө",
    "tooltip": false,
    "on-click": "sh $HOME/.config/hypr/scripts/wlogout.sh"
  },
  "tray": {
    "icon-size": 18,
    "margin": 4,
    "spacing": 10,
    "tooltip": true,
    "format": "{icon}",
    "tooltip-format": "{icon} {status}",
    "tooltip-size": 20
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пғ§",
      "performance": "<span color='#B37F34'><small>пғ§</small></span>",
      "balanced": "<span><small>пүҺ </small></span>",
      "power-saver": "<span color='#a6e3a1'><small>пҒ¬</small></span>"
    }
  },
  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G у°ҫҶ / {total:0.1f}G",
    "format-alt": "{percentage}% у°ҫҶ",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "kitty --title btop sh -c 'btop'"
  },
  "cpu": {
    "interval": 10,
    "format": "у°ҳҡ {usage}уұүё"
  },
  "disk": {
    "interval": 60,
    "format": "у°Ҷј {percentage_used}уұүё",
    "path": "/"
  },
  "mpris": {
    "interval": 10,
    "format": "{player_icon} ",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",
    "smooth-scrolling-threshold": 1,
    "player-icons": {
      "chromium": "пүЁ",
      "default": "пҖқ",
      "firefox": "пү©",
      "kdeconnect": "пҳҹ",
      "mopidy": "пҖҒ",
      "mpv": "у°җ№",
      "spotify": "пҶј",
      "vlc": "у°•ј"
    },
    "status-icons": {
      "paused": "у°җҺ",
      "playing": "пҒӢ",
      "stopped": "пҒҚ"
    },
    "ignored-players": [
      "firefox"
    ],
    "max-length": 30
  },
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "sort-by-number": true,
    "format": "{icon} {name}",
    "show-special": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "active": "пҶ’",
      "default": "п„Ң"
    }
  },
  "clock": {
    "format": "<span color='#b4befe'>пҖ— </span> {:%I:%M %p  %A, %b %d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "pulseaudio": {
    "format": "<span color='#b4befe'>{icon} </span> {volume}%",
    "format-muted": "у°қҹ ",
    "tooltip": false,
    "format-icons": {
      "headphone": "пҖҘ",
      "default": [
        "пҖҰ",
        "пҖ§",
        "у°•ҫ",
        "у°•ҫ",
        "у°•ҫ",
        "пҖЁ",
        "пҖЁ",
        "пҖЁ"
      ]
    },
    "scroll-step": 1,
    "on-scroll-up": "~/.config/hypr/scripts/volume.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/volume.sh --dec",
    "on-click": "~/.config/hypr/scripts/volume.sh --toggle"
  },
 
  "network": {
    "interface": "wlo1",
    "format": "{ifname}",
    "format-wifi": "{icon}  {essid}",
    "format-ethernet": "оҪ„ ",
    "format-disconnected": "у°ӨҜ ",
    "tooltip-format": "{ipaddr} п„№ {bandwidthUpBits} п„ә {bandwidthDownBits}",
    "format-linked": "у°ҲҒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} у°Ңҳ",
    "tooltip-format-disconnected": "у°Ңҷ Disconnected",
    "max-length": 30,
    "format-icons": [
      "у°ӨҜ",
      "у°Өҹ",
      "у°Өў",
      "у°ӨҘ",
      "у°ӨЁ"
    ],
    "on-click-right": "~/.config/hypr/scripts/network.sh",
    "on-click": "nm-connection-editor"
  },
  "network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "п„ә {bandwidthDownBytes} п„№ {bandwidthUpBytes} ",
    "format-ethernet": "{icon}п„ә {bandwidthDownBytes} п„ә {bandwidthUpBytes} ",
    "format-disconnected": "у°Ңҷ",
    "tooltip-format": "{ipaddr}",
    "format-linked": "у°ҲҒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} у°Ңҳ",
    "tooltip-format-disconnected": "у°Ңҷ Disconnected",
    "max-length": 30
  },
 
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "пӮў<span foreground='red'><sup>п‘„</sup></span>",
      "none": "пӮў",
      "dnd-notification": "пҮ·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-none": "пҮ·",
      "inhibited-notification": "пӮў<span foreground='red'><sup>п‘„</sup></span>",
      "inhibited-none": "пӮў",
      "dnd-inhibited-notification": "пҮ·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-inhibited-none": "пҮ·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}

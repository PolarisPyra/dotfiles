{
  "layer": "top",
  "output": "DP-6",
  "modules-center": ["hyprland/workspaces"],
  "modules-left": ["custom/os", "custom/swaync", "memory", "cpu", "disk", "privacy"],
  "modules-right": ["clock", "tray", "network", "pulseaudio"],
  "privacy": {
    "icon-size": 12,
    "icon-spacing": 5,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 12
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 12
      }
    ]
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 12,
    "height": 10,
    "on-click": "activate",
    "on-click-middle": "close"
  },
  "custom/os": {
    "format": "¾░Żć",
    "tooltip": false,
    "on-click": "sh $HOME/.config/waybar/scripts/logout.sh"
  },
  "tray": {
    "icon-size": 18,
    "margin": 4,
    "spacing": 10,
    "tooltip": true,
    "format": "{icon}",
    "tooltip-format": "{icon} {status}",
    "tooltip-size": 20
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’ā¦",
      "performance": "<span color='#B37F34'><small>’ā¦</small></span>",
      "balanced": "<span><small>’ēÄ </small></span>",
      "power-saver": "<span color='#a6e3a1'><small>’ü¼</small></span>"
    }
  },
  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G ¾░Šå / {total:0.1f}G",
    "format-alt": "{percentage}% ¾░Šå",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "kitty --title btop sh -c 'btop'"
  },
  "cpu": {
    "interval": 10,
    "format": "¾░śÜ {usage}¾▒ēĖ"
  },
  "disk": {
    "interval": 60,
    "format": "¾░å╝ {percentage_used}¾▒ēĖ",
    "path": "/"
  },
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "sort-by-number": true,
    "format": "{icon} {name}",
    "show-special": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "active": "’åÆ",
      "default": "’äī"
    }
  },
  "clock": {
    "format": "<span color='#b4befe'>’ĆŚ </span> {:%I:%M %p  %A, %b %d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "pulseaudio": {
    "format": "<span color='#b4befe'>{icon} </span> {volume}%",
    "format-muted": "¾░Ø¤ ",
    "tooltip": false,
    "format-icons": {
      "headphone": "’Ćź",
      "default": ["’Ć”", "’Ć¦", "¾░ĢŠ", "¾░ĢŠ", "¾░ĢŠ", "’Ć©", "’Ć©", "’Ć©"]
    },
    "scroll-step": 1,
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },
  "network": {
    "interface": "enp8s0",
    "format": "{ifname}",
    "format-wifi": "{icon}  {essid}",
    "format-ethernet": "ŅĮä ",
    "format-disconnected": "¾░ż» ",
    "tooltip-format": "{ipaddr} ’ä╣ {bandwidthUpBits} ’ä║ {bandwidthDownBits}",
    "format-linked": "¾░łü {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ¾░īś",
    "tooltip-format-disconnected": "¾░īÖ Disconnected",
    "max-length": 30,
    "format-icons": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
    "on-click": "nm-connection-editor"
  },
  "network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "’ä║ {bandwidthDownBytes} ’ä╣ {bandwidthUpBytes} ",
    "format-ethernet": "{icon}’ä║ {bandwidthDownBytes} ’ä║ {bandwidthUpBytes} ",
    "format-disconnected": "¾░īÖ",
    "tooltip-format": "{ipaddr}",
    "format-linked": "¾░łü {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ¾░īś",
    "tooltip-format-disconnected": "¾░īÖ Disconnected",
    "max-length": 30
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "’éó<span><sup>’æä </sup></span>",
      "none": "’éó ",
      "dnd-notification": "’ćĘ<span><sup>’æä </sup></span>",
      "dnd-none": "’ćĘ ",
      "inhibited-notification": "’éó<span><sup>’æä </sup></span>",
      "inhibited-none": "’éó ",
      "dnd-inhibited-notification": "’ćĘ<span ><sup>’æä </sup></span>",
      "dnd-inhibited-none": "’ćĘ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
